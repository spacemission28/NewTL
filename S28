void OnTick()
{
    bool is_connected = TerminalInfoInteger(TERMINAL_CONNECTED);
    static bool g_was_disconnected = false;
    if (!is_connected)
    {
        g_was_disconnected = true;
        return;
    }

    if (g_was_disconnected && is_connected)
    {
        Print("CRITICAL: CONNECTION REGAINED. Performing trade state reconciliation.");
        RebuildInternalState();
        g_was_disconnected = false;
    }
}

