//+------------------------------------------------------------------+
//| PlaceOcoOrders — Handles straddle placement and TIF expiration   |
//+------------------------------------------------------------------+
void PlaceOcoOrders(double signal_high, double signal_low, datetime signal_close_time, double ma_value, bool place_buy, bool place_sell)
{
    double risk_amount_acct_curr = (RPTFixedAmount > 0) ? RPTFixedAmount : account.Balance() * (RPTPercent / 100.0);
    
    if(risk_amount_acct_curr <= 0 || g_conversion_rate <= 0.0)
    {
        Print("PlaceOcoOrders: Invalid Risk or Conversion Rate. Aborting.");
        return;
    }

    long magic_number = g_next_magic_id;
    CTradeGroup *group = GetTradeGroup(magic_number, true);
    if(group == NULL) return;
    
    group.signal_high = signal_high;
    group.signal_low = signal_low;
    
    // TIF LOGIC: Orders expire at the close of the candle FOLLOWING the signal candle
    group.expiration_time = signal_close_time + PeriodSeconds(GetNativeTimeframe(Inp_Timeframe));

    // Place Buy Side if valid
    if(place_buy)
    {
        PlaceOrdersForSide(magic_number, ORDER_TYPE_BUY_STOP, signal_high, signal_low, risk_amount_acct_curr, signal_close_time);
    }
    
    // Place Sell Side if valid
    if(place_sell)
    {
        PlaceOrdersForSide(magic_number, ORDER_TYPE_SELL_STOP, signal_high, signal_low, risk_amount_acct_curr, signal_close_time);
    }

    // Register for OCO monitoring
    S_OcoVerificationRequest *request = new S_OcoVerificationRequest();
    if(request != NULL)
    {
        request.magic_number = magic_number;
        // Start checking for fills shortly after the expiration window
        request.check_after_time = group.expiration_time + 10;
        g_verification_queue.Add(request);
    }
}

//+------------------------------------------------------------------+
//| Places orders for one side (GTC)                                 |
//+------------------------------------------------------------------+
void PlaceOrdersForSide(long magic_number, ENUM_ORDER_TYPE orderType, double signal_high, double signal_low, double risk_amount_acct_curr, datetime candle_close_time)
{
    const int total_orders = TOTAL_TPS;
    double candle_height = signal_high - signal_low;
    
    if(MathAbs(candle_height) < _Point) return;

    double entry_pct_input = Inp_TriggerPercent_Half;
    double sl_pct_input = Inp_StopLossPercent_Half;

    double entry_buffer = candle_height * (entry_pct_input / 100.0);
    double sl_buffer = candle_height * (sl_pct_input / 100.0);

    double entry_price = (orderType == ORDER_TYPE_BUY_STOP) ? NormalizePrice(signal_high + entry_buffer) : NormalizePrice(signal_low - entry_buffer);
    double sl_price = (orderType == ORDER_TYPE_BUY_STOP) ? NormalizePrice(signal_low - sl_buffer) : NormalizePrice(signal_high + sl_buffer);

    // --- NEW LOGIC FOR CALCULATED RISK BASIS ---
    double sl_price_for_lot = sl_price;
    if(Inp_LotSizeBasis == LB_X1_Boundary)
    {
        // Maintain lot size AS IF the Stop loss was at the X1 candle Low (Buy) or High (Sell)
        sl_price_for_lot = (orderType == ORDER_TYPE_BUY_STOP) ? NormalizePrice(signal_low) : NormalizePrice(signal_high);
    }

    double tp_distances[] = {TP1_Distance, TP2_Distance};
    double tp_volumes[] = {TP1_Volume/100.0, TP2_Volume/100.0};
    
    CTradeGroup *group = GetTradeGroup(magic_number);
    if(group == NULL) return;
    
    CArrayLong *tickets_array = (orderType == ORDER_TYPE_BUY_STOP) ? &group.buy_stop_tickets : &group.sell_stop_tickets;
    trade.SetExpertMagicNumber(magic_number);

    int orders_placed = 0;
    for(int i = 0; i < total_orders; i++)
    {
        double tp_distance_price = candle_height * (tp_distances[i] / 100.0);
        double tp_price = (orderType == ORDER_TYPE_BUY_STOP) ? NormalizePrice(signal_high + tp_distance_price) : NormalizePrice(signal_low - tp_distance_price);

        if (i == 0) group.tp1_threshold_price = tp_price;
        if(tp_volumes[i] <= 0) continue;

        double riskForThisOrder = risk_amount_acct_curr * tp_volumes[i];
        
        // Pass the Virtual SL Basis to the calculation function
        double lot_size = CalculateLotSize(riskForThisOrder, sl_price_for_lot, entry_price);

        if(lot_size < SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN))
        {
            PrintFormat("LOT SIZE WARNING (Magic %d, TP%d): Calculated lot (%.2f) too small. Skipped.", magic_number, i+1, lot_size);
            continue;
        }

        MqlTradeRequest request; ZeroMemory(request);
        MqlTradeResult result; ZeroMemory(result);

        request.action       = TRADE_ACTION_PENDING;
        request.magic        = magic_number;
        request.symbol       = _Symbol;
        request.volume       = lot_size;
        request.price        = entry_price;
        request.sl           = sl_price; // This is the ACTUAL stop loss placed on the server
        request.tp           = tp_price;
        request.type         = orderType;
        request.type_filling = (ENUM_ORDER_TYPE_FILLING)SymbolInfoInteger(_Symbol, SYMBOL_FILLING_MODE);
        request.type_time    = ORDER_TIME_GTC;
        request.comment      = StringFormat("TP%d_%.0f_%llu", i+1, tp_distances[i], magic_number);

        if(trade.OrderSend(request, result))
        {
            tickets_array.Add((long)result.order);
            orders_placed++;
            PrintFormat("Magic %d: Placed TP%d ticket %llu at %.5f (SL Basis used: %.5f)", magic_number, i+1, result.order, entry_price, sl_price_for_lot);
        }
        else
            PrintFormat("Magic %d: OrderSend FAILED for TP%d | ret=%d comment=%s", magic_number, i+1, result.retcode, result.comment);
    }
    if(orders_placed == 0)
        PrintFormat("Magic %d: WARNING - No orders placed. TP1_Vol=%.0f%% TP2_Vol=%.0f%% | Check lot size or OrderSend errors above.", magic_number, TP1_Volume, TP2_Volume);
}

//+------------------------------------------------------------------+
//| Calculate Lot Size                                               |
//+------------------------------------------------------------------+
double CalculateLotSize(double risk_amount_acct_curr, double sl_price, double entry_price)
{
    double contract_size = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_CONTRACT_SIZE);
    if(contract_size <= 0) return 0.0;

    double sl_distance = MathAbs(entry_price - sl_price);
    if(sl_distance <= 0) return 0.0;

    double risk_per_lot_quote_curr = sl_distance * contract_size;
    double risk_per_lot_acct_curr = risk_per_lot_quote_curr * g_conversion_rate;

    if(Commissions == Commission_Yes)
    {
        double commission_cost_acct_curr = 0;
        if(CommissionType == FX_per_Lot) commission_cost_acct_curr = 2.0 * CommissionsValue; 
        else if(CommissionType == ETF_Stock) commission_cost_acct_curr = (2.0 * 0.02) * g_conversion_rate;
        risk_per_lot_acct_curr += commission_cost_acct_curr;
    }

    if(risk_per_lot_acct_curr <= 0) return 0.0;
    double lot_size = risk_amount_acct_curr / risk_per_lot_acct_curr;

    double step_vol = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_STEP);
    lot_size = MathMax(lot_size, SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN));
    lot_size = MathMin(lot_size, SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MAX));
    lot_size = floor(lot_size / step_vol) * step_vol;

    return NormalizeDouble(lot_size, 2);
}

//+------------------------------------------------------------------+
//| BREAK EVEN MONITOR                                               |
//+------------------------------------------------------------------+
void MonitorBreakEvenStops()
{
    if (Inp_TrailStop == TS_Off) return;

    for(int i = 0; i < g_trade_groups.Total(); i++)
    {
        CTradeGroup *group = (CTradeGroup*)g_trade_groups.At(i);
        if(group == NULL || group.breakeven_applied || group.tp1_threshold_price == 0) continue;

        bool threshold_reached = false;
        ENUM_POSITION_TYPE group_dir = -1;

        for(int j = 0; j < PositionsTotal(); j++)
        {
            ulong pos_ticket = PositionGetTicket(j);
            if(PositionSelectByTicket(pos_ticket) && PositionGetInteger(POSITION_MAGIC) == group.magic_number)
            {
                group_dir = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);
                double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
                double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
                double current_price = (group_dir == POSITION_TYPE_BUY) ? bid : ask;

                if((group_dir == POSITION_TYPE_BUY && current_price >= group.tp1_threshold_price) ||
                   (group_dir == POSITION_TYPE_SELL && current_price <= group.tp1_threshold_price))
                {
                    threshold_reached = true;
                }
                break; 
            }
        }

        if(threshold_reached)
        {
            bool all_modified = true;
            for(int j = 0; j < PositionsTotal(); j++)
            {
                ulong pos_ticket = PositionGetTicket(j);
                if(PositionSelectByTicket(pos_ticket) && PositionGetInteger(POSITION_MAGIC) == group.magic_number)
                {
                    double open_price = PositionGetDouble(POSITION_PRICE_OPEN);
                    double current_sl = PositionGetDouble(POSITION_SL);

                    if(MathAbs(current_sl - open_price) > _Point)
                    {
                        if(!trade.PositionModify(pos_ticket, open_price, PositionGetDouble(POSITION_TP)))
                        {
                            all_modified = false;
                            PrintFormat("Magic %d: Failed to BE ticket %llu", group.magic_number, pos_ticket);
                        }
                    }
                }
            }
            if(all_modified)
            {
                group.breakeven_applied = true;
                PrintFormat("Magic %d: Global BE Applied.", group.magic_number);
            }
        }
    }
}

//+------------------------------------------------------------------+
//| Verify and Clean OCO Imbalance                                   |
//+------------------------------------------------------------------+
bool VerifyAndCleanOcoImbalance(long magic_number)
{
    bool position_exists = false;
    for(int i = 0; i < PositionsTotal(); i++)
    {
        if(PositionSelectByTicket(PositionGetTicket(i)) && PositionGetInteger(POSITION_MAGIC) == magic_number)
        {
            position_exists = true;
            break;
        }
    }

    if(position_exists)
    {
        CTradeGroup *group = GetTradeGroup(magic_number);
        if(group != NULL)
        {
            DeleteAllTickets(group.buy_stop_tickets, "BUY", magic_number);
            DeleteAllTickets(group.sell_stop_tickets, "SELL", magic_number);
        }
        return true;
    }
    return false;
}

//+------------------------------------------------------------------+
//| Delete all tickets in an array                                   |
//+------------------------------------------------------------------+
bool DeleteAllTickets(CArrayLong& tickets_array, string side, long magic_number)
{
    bool all_deleted = true;
    for(int i = tickets_array.Total() - 1; i >= 0; i--)
    {
        ulong ticket = tickets_array.At(i);
        if(OrderSelect(ticket))
        {
            if(!trade.OrderDelete(ticket))
            {
                all_deleted = false;
                PrintFormat("Magic %d: Failed to delete %s ticket %llu", magic_number, side, ticket);
            }
            else tickets_array.Delete(i);
        }
        else tickets_array.Delete(i);
    }
    return all_deleted;
}

//+------------------------------------------------------------------+
//| End-of-Day Cleanup                                               |
//+------------------------------------------------------------------+
void PerformEODCleanup()
{
    Print("EOD Cleanup: Clearing all pending orders.");
    for(int i = OrdersTotal() - 1; i >= 0; i--)
    {
        ulong ticket = OrderGetTicket(i);
        if(OrderSelect(ticket)) trade.OrderDelete(ticket);
    }

    for(int i = 0; i < g_trade_groups.Total(); i++)
    {
        CTradeGroup *group = (CTradeGroup*)g_trade_groups.At(i);
        if(group != NULL)
        {
            group.buy_stop_tickets.Clear();
            group.sell_stop_tickets.Clear();
        }
    }
}

//+------------------------------------------------------------------+
//| Time-in-Force Cleanup — Extinguishes pending orders that have    |
//| not triggered by the close of the candle immediately following X1|
//+------------------------------------------------------------------+
void PerformTIFCleanup()
{
    datetime currentTime = TimeCurrent();
    for(int i = 0; i < g_trade_groups.Total(); i++)
    {
        CTradeGroup *group = (CTradeGroup*)g_trade_groups.At(i);
        if(group == NULL || group.expiration_time == 0) continue;

        if(currentTime >= group.expiration_time)
        {
            bool has_open_pos = false;
            for(int j = 0; j < PositionsTotal(); j++)
            {
                if(PositionSelectByTicket(PositionGetTicket(j)) && PositionGetInteger(POSITION_MAGIC) == group.magic_number)
                {
                    has_open_pos = true;
                    break;
                }
            }

            if(!has_open_pos)
            {
                if(group.buy_stop_tickets.Total() > 0 || group.sell_stop_tickets.Total() > 0)
                {
                    PrintFormat("Magic %d: TIF Expiry reached.", group.magic_number);
                    DeleteAllTickets(group.buy_stop_tickets, "BUY", group.magic_number);
                    DeleteAllTickets(group.sell_stop_tickets, "SELL", group.magic_number);
                }
            }
        }
    }
}

