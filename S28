CTradeGroup* GetTradeGroup(long magic, bool create_if_not_exists = false)
{
    for(int i = 0; i < g_trade_groups.Total(); i++)
    {
        CTradeGroup *group = (CTradeGroup*)g_trade_groups.At(i);
        if(group != NULL && group.magic_number == magic) return group;
    }
    if(create_if_not_exists)
    {
        CTradeGroup *new_group = new CTradeGroup();
        new_group.magic_number = magic;
        g_trade_groups.Add(new_group);
        return new_group;
    }
    return NULL;
}

void RebuildInternalState()
{
    g_trade_groups.Clear();
    g_next_magic_id = Inp_BaseMagicNumber;  // Reset so we derive next id from all relevant orders/positions
    
    string chart_symbol = _Symbol;
    for(int i = 0; i < PositionsTotal(); i++)
    {
        ulong ticket = PositionGetTicket(i);
        if(PositionSelectByTicket(ticket))
        {
            if(PositionGetString(POSITION_SYMBOL) != chart_symbol) continue;
            long magic = PositionGetInteger(POSITION_MAGIC);
            if(magic >= (long)Inp_BaseMagicNumber)
            {
                CTradeGroup *group = GetTradeGroup(magic, true);
                group.open_position_tickets.Add((long)ticket);
                if(magic >= (long)g_next_magic_id) g_next_magic_id = magic + 1;
            }
        }
    }
    for(int i = 0; i < OrdersTotal(); i++)
    {
        ulong ticket = OrderGetTicket(i);
        if(OrderSelect(ticket))
        {
            if(OrderGetString(ORDER_SYMBOL) != chart_symbol) continue;
            long magic = OrderGetInteger(ORDER_MAGIC);
            if(magic >= (long)Inp_BaseMagicNumber)
            {
                CTradeGroup *group = GetTradeGroup(magic, true);
                long type = OrderGetInteger(ORDER_TYPE);
                if(type == ORDER_TYPE_BUY_STOP) group.buy_stop_tickets.Add((long)ticket);
                if(type == ORDER_TYPE_SELL_STOP) group.sell_stop_tickets.Add((long)ticket);
                if(magic >= (long)g_next_magic_id) g_next_magic_id = magic + 1;
            }
        }
    }
}

