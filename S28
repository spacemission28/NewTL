//+------------------------------------------------------------------+
//| Clean stale pending tickets + direction filter                   |
//+------------------------------------------------------------------+
int CleanStalePendingTickets(CArrayLong &tickets, long magic_number, string comment_prefix = "")
{
   if(tickets.Total() == 0) return 0;

   trade.SetExpertMagicNumber(magic_number);
   int removed = 0;
   int i = tickets.Total() - 1;
   while(i >= 0)
   {
      ulong ticket = tickets.At(i);
      if(ticket <= 0)
      {
         tickets.Delete(i);
         removed++;
         i--;
         continue;
      }

      if(!OrderSelect(ticket))
      {
         tickets.Delete(i);
         removed++;
         i--;
         continue;
      }

      long   ord_magic = OrderGetInteger(ORDER_MAGIC);
      string ord_sym   = OrderGetString(ORDER_SYMBOL);
      long   ord_state = OrderGetInteger(ORDER_STATE);
      long   ord_type  = OrderGetInteger(ORDER_TYPE);

      bool direction_match = false;
      if((Inp_Direction == BUY_Only || Inp_Direction == BUY_SELL) && ord_type == ORDER_TYPE_BUY_STOP) direction_match = true;
      if((Inp_Direction == SELL_Only || Inp_Direction == BUY_SELL) && ord_type == ORDER_TYPE_SELL_STOP) direction_match = true;

      if(ord_magic != magic_number ||
         ord_sym   != _Symbol ||
         ord_state != ORDER_STATE_PLACED ||
         !direction_match)
      {
         tickets.Delete(i);
         removed++;
      }

      i--;
   }

   return removed;
}

//+------------------------------------------------------------------+
//| Expert initialization function                                   |
//+------------------------------------------------------------------+
int OnInit()
{
    if(!TerminalInfoInteger(TERMINAL_CONNECTED))
    {
        Print("Client OnInit failed: No terminal connection.");
        return(INIT_FAILED);
    }

    double total_tp_volume = TP1_Volume + TP2_Volume;
    if(MathAbs(total_tp_volume - 100.0) > 0.01)
    {
        PrintFormat("CRITICAL ERROR: TP volumes sum to %.2f%%. They must sum to 100.0%%.", total_tp_volume);
        return(INIT_FAILED);
    }

    string norm_symbol = GetNormalizedSymbol();
    string tf_str = TimeframeToString(Inp_Timeframe);
    g_gv_prefix = "CCM_" + norm_symbol + "_" + tf_str + "_";
    g_gv_commit_key = g_gv_prefix + "COMMIT_ID";

    for (int i = 0; i < CANDLE_LOOKBACK; i++) 
    {
        g_gv_time_keys[i]     = g_gv_prefix + "TIME_"     + IntegerToString(i);
        g_gv_high_keys[i]     = g_gv_prefix + "HIGH_"     + IntegerToString(i);
        g_gv_low_keys[i]      = g_gv_prefix + "LOW_"      + IntegerToString(i);
        g_gv_height_keys[i]   = g_gv_prefix + "HEIGHT_"   + IntegerToString(i);
        g_gv_ma_keys[i]       = g_gv_prefix + "MA_"       + IntegerToString(i);
    }

    string quote_currency = SymbolInfoString(_Symbol, SYMBOL_CURRENCY_MARGIN);
    string acct_currency = AccountInfoString(ACCOUNT_CURRENCY);
    
    const int max_init_attempts = 100;
    bool init_rate_success = false;
    for(int i = 1; i <= max_init_attempts; i++)
    {
        g_conversion_rate = GetConversionRate(quote_currency, acct_currency);
        if(g_conversion_rate > 0)
        {
            Print("Successfully obtained FX rate for risk calculation.");
            init_rate_success = true;
            break;
        }

        if(i == max_init_attempts)
        {
            PrintFormat("Failed to get FX rate after %d attempts. Lot sizing will fail.", max_init_attempts);
            return(INIT_FAILED);
        }

        if(i % 10 == 0)
            Print("Still attempting to fetch FX conversion rate...");
        Sleep(100); 
    }

    g_last_conversion_rate_time = TimeCurrent();
    g_next_magic_id = Inp_BaseMagicNumber;

    if(!Inp_ResetGlobalVars)
    {
        if(GlobalVariableCheck(GVarLastCandleTimeName()))
            g_last_gv_processed_time = (datetime)GlobalVariableGet(GVarLastCandleTimeName());
        else if(GlobalVariableCheck(g_gv_commit_key))
            g_last_gv_processed_time = (datetime)GlobalVariableGet(g_gv_commit_key);
        else
            g_last_gv_processed_time = 0;
    }
    else
    {
         g_last_gv_processed_time = 0;
         GlobalVariableDel(GVarLastCandleTimeName());
    }

    RebuildInternalState();
    EventSetTimer((int)Inp_TimerInterval);

    string dir_str = (Inp_Direction == BUY_Only) ? "BUY only" : (Inp_Direction == SELL_Only) ? "SELL only" : "BUY & SELL";
    string ma_str  = (Inp_MAFilter == MA_Filter_On) ? "MA filter ON" : "MA filter OFF";

    PrintFormat("EA Initialised. Polling: '%s' | Magic: %d | Mode: %s | %s", g_gv_commit_key, Inp_BaseMagicNumber, dir_str, ma_str);
    return(INIT_SUCCEEDED);
}

//+------------------------------------------------------------------+
//| Deinitialization Function                                        |
//+------------------------------------------------------------------+
void OnDeinit(const int reason)
{
    GlobalVariableSet(GVarLastCandleTimeName(), g_last_gv_processed_time);
    
    string saved_state_name = GVarSavedTradeStateName();
    string trade_state = SerializeOpenTrades();
    if (StringLen(trade_state) > 0) {
        SaveTradeStateToFile(saved_state_name, trade_state);
    }
    
    for(int i = 0; i < g_trade_groups.Total(); i++)
    {
        CTradeGroup *group = (CTradeGroup*)g_trade_groups.At(i);
        if(group != NULL) delete group;
    }
    g_trade_groups.Clear();

    for(int i = 0; i < g_verification_queue.Total(); i++)
    {
        S_OcoVerificationRequest *request = (S_OcoVerificationRequest*)g_verification_queue.At(i);
        if(request != NULL) delete request;
    }
    g_verification_queue.Clear();
    
    EventKillTimer();
    Print("TradeLogic Client deinitialized. Reason: ", reason);
}

//+------------------------------------------------------------------+
//| OnTimer Function — Optimized for Independent Straddle Logic      |
//+------------------------------------------------------------------+
void OnTimer()
{
    datetime currentTime = TimeCurrent();
    long period_seconds = PeriodSeconds(GetNativeTimeframe(Inp_Timeframe));

    // HOUSEKEEPING BLOCK 1: OCO Verification (Cancels opposite side upon fill)
    for(int i = g_verification_queue.Total() - 1; i >= 0; i--)
    {
        S_OcoVerificationRequest *request = (S_OcoVerificationRequest*)g_verification_queue.At(i);
        if(request != NULL && currentTime >= request.check_after_time)
        {
            if(VerifyAndCleanOcoImbalance(request.magic_number))
            {
                delete request;
                g_verification_queue.Delete(i);
            }
            else
            {
                request.check_after_time = currentTime + 10;
            }
        }
    }

    // HOUSEKEEPING BLOCK 2: CONVERSION RATE REFRESH
    if(period_seconds > 0)
    {
        datetime next_candle_close_time = (currentTime / period_seconds + 1) * period_seconds;
        datetime refresh_start_time = next_candle_close_time - 5;

        if (currentTime >= refresh_start_time && currentTime < next_candle_close_time && g_last_conversion_rate_time < refresh_start_time)
        {
            string quote_currency = SymbolInfoString(_Symbol, SYMBOL_CURRENCY_MARGIN);
            string acct_currency = AccountInfoString(ACCOUNT_CURRENCY);
            double new_rate = GetConversionRate(quote_currency, acct_currency);
            
            if(new_rate > 0)
            {
                g_conversion_rate = new_rate;
                g_last_conversion_rate_time = currentTime;
                Print("Successfully obtained FRESH FX rate.");
            }
        }
    }

    // HOUSEKEEPING BLOCK 3: STALENESS MONITOR
    string status_key = g_gv_prefix + "STATUS";
    if (GlobalVariableCheck(status_key))
    {
        datetime status_time = (datetime)GlobalVariableGet(status_key);
        if (status_time > 0 && currentTime - status_time > period_seconds * 3)
        {
            if (currentTime - g_last_staleness_log_time >= 600)
            {
                PrintFormat("STALENESS WARNING: Data feed for %s stalled.", _Symbol);
                g_last_staleness_log_time = currentTime;
            }
        }
    }

    // HOUSEKEEPING BLOCK 4: BREAK EVEN MONITOR
    MonitorBreakEvenStops();

    // HOUSEKEEPING BLOCK 5: TIME-IN-FORCE CLEANUP
    PerformTIFCleanup();

    // EOD CHECK
    if (Inp_EndDay == ED_Yes)
    {
        datetime day_start = currentTime - (currentTime % 86400);
        datetime eod_time = day_start + (Inp_EndHour * 3600) + (Inp_EndMinute * 60);
        if (currentTime >= eod_time - 60 && currentTime < eod_time)
        {
            if(currentTime - g_last_eod_check > 60) { 
                PerformEODCleanup();
                g_last_eod_check = currentTime;
            }
            return;
        }
    }

    // TRADING LOGIC GATES
    if(Inp_AutoTrading == On)
    {
        if (!GlobalVariableCheck(g_gv_commit_key)) return;
        datetime commit_time = (datetime)GlobalVariableGet(g_gv_commit_key);
        
        // Corrected index: Index 0 is the newest candle from CCM data feed
        int latest_index = 0; 
        
        datetime candle_time   = (datetime)GlobalVariableGet(g_gv_time_keys[latest_index]);
        double   candle_high   = (double)GlobalVariableGet(g_gv_high_keys[latest_index]);
        double   candle_low    = (double)GlobalVariableGet(g_gv_low_keys[latest_index]);
        double   candle_height = (double)GlobalVariableGet(g_gv_height_keys[latest_index]);
        double   ma_value      = (double)GlobalVariableGet(g_gv_ma_keys[latest_index]);

        if(candle_time == 0 || candle_time != commit_time) return;

        static datetime last_placed_candle_time = 0;
        if (candle_time <= last_placed_candle_time) return;
        if(candle_height < MinX1Height) return;

        // --- INDEPENDENT SIGNAL EVALUATION (STRADDLE SUPPORT) ---
        bool place_buy = false;
        bool place_sell = false;

        // Evaluate BUY Side
        if(Inp_Direction == BUY_Only || Inp_Direction == BUY_SELL)
        {
            if(Inp_MAFilter == MA_Filter_Off || candle_low > ma_value) 
                place_buy = true;
        }

        // Evaluate SELL Side independently (No 'else' to allow simultaneous triggers)
        if(Inp_Direction == SELL_Only || Inp_Direction == BUY_SELL)
        {
            if(Inp_MAFilter == MA_Filter_Off || candle_high < ma_value) 
                place_sell = true;
        }

        if(place_buy || place_sell)
        {
            PrintFormat("[SIGNAL] %s Accepted | Buy: %s | Sell: %s", 
                        TimeToString(candle_time), (string)place_buy, (string)place_sell);
            
            datetime close_time = candle_time + period_seconds;
            PlaceOcoOrders(candle_high, candle_low, close_time, ma_value, place_buy, place_sell);
            
            last_placed_candle_time = candle_time;
            g_next_magic_id++;
        }
    }
}

