}

//+------------------------------------------------------------------+
//| Direct rate: 1 unit from_currency = ? to_currency                 |
//| Supports cross-rates via common base currencies (USD, EUR, GBP)   |
//+------------------------------------------------------------------+
double GetConversionRate(string from_currency, string to_currency)
{
    if(from_currency == to_currency) return 1.0;
    
    // 1. Try direct or inverse pair
    for(int i = 0; i < SymbolsTotal(false); i++)
    {
        string symbol = SymbolName(i, false);
        string base_curr, quote_curr;
        if(!SymbolInfoString(symbol, SYMBOL_CURRENCY_BASE, base_curr)) continue;
        if(!SymbolInfoString(symbol, SYMBOL_CURRENCY_PROFIT, quote_curr)) continue;
        
        if(base_curr == from_currency && quote_curr == to_currency)
        {
            double bid = SymbolInfoDouble(symbol, SYMBOL_BID);
            if(bid > 0) return bid;
        }
        if(base_curr == to_currency && quote_curr == from_currency)
        {
            double ask = SymbolInfoDouble(symbol, SYMBOL_ASK);
            if(ask > 0) return 1.0 / ask; 
        }
    }
    
    // 2. Route through common base currencies (cross-rate)
    string common_bases[] = {"USD", "EUR", "GBP"};
    for(int c = 0; c < ArraySize(common_bases); c++)
    {
        string hub = common_bases[c];
        if(hub == from_currency || hub == to_currency) continue;
        
        double rate_to_hub = 0.0, rate_from_hub = 0.0;
        for(int i = 0; i < SymbolsTotal(false); i++)
        {
            string symbol = SymbolName(i, false);
            string base_curr, quote_curr;
            if(!SymbolInfoString(symbol, SYMBOL_CURRENCY_BASE, base_curr)) continue;
            if(!SymbolInfoString(symbol, SYMBOL_CURRENCY_PROFIT, quote_curr)) continue;
            
            if(base_curr == from_currency && quote_curr == hub)
            {
                double bid = SymbolInfoDouble(symbol, SYMBOL_BID);
                if(bid > 0) { rate_to_hub = bid; break; }
            }
            if(base_curr == hub && quote_curr == from_currency)
            {
                double ask = SymbolInfoDouble(symbol, SYMBOL_ASK);
                if(ask > 0) { rate_to_hub = 1.0 / ask; break; }
            }
        }
        if(rate_to_hub <= 0) continue;
        
        for(int i = 0; i < SymbolsTotal(false); i++)
        {
            string symbol = SymbolName(i, false);
            string base_curr, quote_curr;
            if(!SymbolInfoString(symbol, SYMBOL_CURRENCY_BASE, base_curr)) continue;
            if(!SymbolInfoString(symbol, SYMBOL_CURRENCY_PROFIT, quote_curr)) continue;
            
            if(base_curr == hub && quote_curr == to_currency)
            {
                double bid = SymbolInfoDouble(symbol, SYMBOL_BID);
                if(bid > 0) { rate_from_hub = bid; break; }
            }
            if(base_curr == to_currency && quote_curr == hub)
            {
                double ask = SymbolInfoDouble(symbol, SYMBOL_ASK);
                if(ask > 0) { rate_from_hub = 1.0 / ask; break; }
            }
        }
        if(rate_from_hub > 0) return rate_to_hub * rate_from_hub;
    }
    
    return 0.0;
}
