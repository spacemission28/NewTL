            DeleteAllTickets(group.buy_stop_tickets, "EOD_BUY", group.magic_number);
            DeleteAllTickets(group.sell_stop_tickets, "EOD_SELL", group.magic_number);
            
            // And close positions
            for (int j = PositionsTotal() - 1; j >= 0; j--)
