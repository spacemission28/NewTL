string GetNormalizedSymbol()
{
    string symbol = _Symbol;
    StringReplace(symbol, "/", "");
    // Strip user-specified suffix/prefix if provided
    if (Inp_SymbolSuffix != "")
    {
        int suffix_len = StringLen(Inp_SymbolSuffix);
        if (suffix_len > 0)
        {
            // CORRECTED: Check for suffix using StringSubstr
            if (StringLen(symbol) >= suffix_len && StringSubstr(symbol, StringLen(symbol) - suffix_len, suffix_len) == Inp_SymbolSuffix)
            {
                symbol = StringSubstr(symbol, 0, StringLen(symbol) - suffix_len);
            }
            // CORRECTED: Check for prefix using StringSubstr
            else if (StringLen(symbol) >= suffix_len && StringSubstr(symbol, 0, suffix_len) == Inp_SymbolSuffix)
            {
                symbol = StringSubstr(symbol, suffix_len);
            }
        }
    }
    return ClientStringUpper(symbol);
}

