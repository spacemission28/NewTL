void RebuildInternalState()
{
    g_trade_groups.Clear();
    
    // --- PASS 1: Find all pending orders and open positions, build the groups ---
    for(int i = OrdersTotal() - 1; i >= 0; i--)
    {
        ulong ticket = OrderGetTicket(i);
        if(OrderSelect(ticket) && OrderGetInteger(ORDER_MAGIC) >= Inp_BaseMagicNumber)
        {
            long magic = OrderGetInteger(ORDER_MAGIC);
            CTradeGroup *group = GetTradeGroup(magic, true);
            if(group == NULL) continue;
            
            if(OrderGetInteger(ORDER_TYPE) == ORDER_TYPE_BUY_STOP)
                group.buy_stop_tickets.Add(ticket);
            else if(OrderGetInteger(ORDER_TYPE) == ORDER_TYPE_SELL_STOP)
                group.sell_stop_tickets.Add(ticket);
                
            if(magic >= g_next_magic_id)
                g_next_magic_id = magic + 1;
        }
    }
    
    for(int i = PositionsTotal() - 1; i >= 0; i--)
    {
        ulong ticket = PositionGetTicket(i);
        if(PositionSelectByTicket(ticket) && PositionGetInteger(POSITION_MAGIC) >= Inp_BaseMagicNumber)
        {
            long magic = PositionGetInteger(POSITION_MAGIC);
            CTradeGroup *group = GetTradeGroup(magic, true);
            if(group == NULL) continue;

            group.open_position_tickets.Add(ticket);
            //group.oco_complete = true; // <<< DO NOT set this here
            
            if(magic >= g_next_magic_id)
                g_next_magic_id = magic + 1;
        }
    }
    
    // --- PASS 2: Now that all groups are built, run OCO logic ---
    for(int i = 0; i < g_trade_groups.Total(); i++)
    {
        CTradeGroup *group = g_trade_groups.At(i);
        if(group == NULL || group.oco_complete) continue;
        
        // --- THIS IS THE FIX ---
        // Set the CTrade object's magic number *before* any delete operations.
        trade.SetExpertMagicNumber(group.magic_number);
        // --- END FIX ---
        
        bool has_buy = false;
        bool has_sell = false;
        
        for(int j = 0; j < group.open_position_tickets.Total(); j++)
        {
            ulong pos_ticket = group.open_position_tickets.At(j);
            if(PositionSelectByTicket(pos_ticket))
            {
                if(PositionGetInteger(POSITION_TYPE) == POSITION_TYPE_BUY) has_buy = true;
                else if(PositionGetInteger(POSITION_TYPE) == POSITION_TYPE_SELL) has_sell = true;
            }
        }

        if(has_buy)
        {
            if(group.sell_stop_tickets.Total() > 0)
            {
                Print("RebuildState: Found open BUY pos for Magic %d. Deleting %d orphaned SELL stops.", group.magic_number, group.sell_stop_tickets.Total());
                if(DeleteAllTickets(group.sell_stop_tickets, "REBUILD_OCO_SELL", group.magic_number))
                {
                    group.oco_complete = true; 
                }
                // If it fails, oco_complete remains false and we try again
            }
            else
            {
                group.oco_complete = true; // No sells to delete
            }
        }
        else if(has_sell)
        {
            if(group.buy_stop_tickets.Total() > 0)
            {
                Print("RebuildState: Found open SELL pos for Magic %d. Deleting %d orphaned BUY stops.", group.magic_number, group.buy_stop_tickets.Total());
                if(DeleteAllTickets(group.buy_stop_tickets, "REBUILD_OCO_BUY", group.magic_number))
                {
                    group.oco_complete = true;
                }
            }
            else
            {
                group.oco_complete = true; // No buys to delete
            }
        }
    }
}


//+------------------------------------------------------------------+
//| Handle OCO logic by polling open positions (CORRECTED)           |
//+------------------------------------------------------------------+
void HandleOCO(long magic_number)
{
    CTradeGroup *group = GetTradeGroup(magic_number);
    if(group == NULL || group.oco_complete) return;
    
    // --- THIS IS THE FIX ---
    // Set the CTrade object's magic number *before* any delete operations.
    trade.SetExpertMagicNumber(magic_number);
    // --- END FIX ---

    bool has_buy = false, has_sell = false;
    for(int i = 0; i < PositionsTotal(); i++)
    {
        if(PositionSelectByTicket(PositionGetTicket(i)) && PositionGetInteger(POSITION_MAGIC) == magic_number)
        {
            if(PositionGetInteger(POSITION_TYPE) == POSITION_TYPE_BUY) has_buy = true;
            else if(PositionGetInteger(POSITION_TYPE) == POSITION_TYPE_SELL) has_sell = true;
        }
    }

    // --- THIS IS THE FIX ---
    // We now check the return value of DeleteAllTickets.
    if(has_buy)
    {
        // If deletion is successful, mark OCO as complete.
        if(DeleteAllTickets(group.sell_stop_tickets, "OCO_SELL", magic_number))
        {
            group.oco_complete = true; // Mark "DONE"
        }
        // If it fails, we do *nothing*. We don't mark it complete,
        // so this function will run again on the next tick.
    }
    else if(has_sell)
    {
        // If deletion is successful, mark OCO as complete.
        if(DeleteAllTickets(group.buy_stop_tickets, "OCO_BUY", magic_number))
        {
            group.oco_complete = true; // Mark "DONE"
        }
        // If it fails, we do *nothing* and will retry.
    }
}

//+------------------------------------------------------------------+
//| HELPER: Verifies OCO PENDING ORDER balance (CORRECTED)           |
//| RETURNS: true if cleanup is complete, false if it failed and needs retry |
//+------------------------------------------------------------------+
bool VerifyAndCleanOcoImbalance(long magic_number)
{
    CTradeGroup *group = GetTradeGroup(magic_number);
    if(group == NULL) return true; // Group doesn't exist, job is "done"
    
    // If OCO is complete, this job is done (HandleOCO took over)
    if(group.oco_complete) return true; 

    // --- THIS IS THE FIX ---
    // Set the CTrade object's magic number
    trade.SetExpertMagicNumber(magic_number);
    // --- END FIX ---

    int buy_stop_count = group.buy_stop_tickets.Total();
    int sell_stop_count = group.sell_stop_tickets.Total();
    
    // Check for the imbalanced condition
    bool is_imbalanced = (buy_stop_count > 0 && sell_stop_count == 0) ||
                         (sell_stop_count > 0 && buy_stop_count == 0);

    if(is_imbalanced)
    {
        PrintFormat("CRITICAL OCO IMBALANCE DETECTED (Magic %d): Pending Buys=%d, Sells=%d. Deleting all pending orders for this group.",
                    magic_number, buy_stop_count, sell_stop_count);
        
        // --- THIS IS THE FIX ---
        // We must delete BOTH sides and check that BOTH are successful.
        bool buys_deleted = DeleteAllTickets(group.buy_stop_tickets, "OCO_IMBALANCE", magic_number);
        bool sells_deleted = DeleteAllTickets(group.sell_stop_tickets, "OCO_IMBALANCE", magic_number);
        
        // Return 'true' (job done) only if both sides are 0.
        return (buys_deleted && sells_deleted);
    }
    else
    {
        PrintFormat("Magic %d: OCO verification passed. Pending Buys=%d, Sells=%d.", magic_number, buy_stop_count, sell_stop_count);
        return true; // Verification passed, job is "done"
    }
}

//+------------------------------------------------------------------+
//| Calculate Lot Size (FULLY CORRECTED - Fixes Contract Size & Commission) |
//+------------------------------------------------------------------+
double CalculateLotSize(double risk_amount_acct_curr, double sl_price, double entry_price, double sl_buffer)
{
    // --- FIX 1: GET CONTRACT SIZE ---
    double contract_size = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_CONTRACT_SIZE);
    if(contract_size <= 0) 
    {
        Print("CalculateLotSize: Failed to get contract size for symbol ", _Symbol);
        return 0.0;
    }
    
    double sl_distance = MathAbs(entry_price - sl_price);
    if (sl_distance <= 0) 
    {
         Print("CalculateLotSize: Invalid SL distance for ", _Symbol);
         return 0.0;
    }
    
    // --- FIX 2: USE CONTRACT SIZE in risk calculation ---
    double risk_per_lot_quote_curr = sl_distance * contract_size;
    double risk_per_lot_acct_curr = risk_per_lot_quote_curr * g_conversion_rate;
    
    if(Commissions == Commission_Yes)
    {
        double commission_cost_acct_curr = 0;
        
        if (CommissionType == FX_per_Lot)
        {
            // --- FIX 3: REMOVE g_conversion_rate from fixed AUD commission ---
            // Assumes CommissionsValue is ALREADY in the account currency (e.g., 7 AUD)
            commission_cost_acct_curr = (2.0 * CommissionsValue);
        }
        else if(CommissionType == ETF_Stock)
        {
            // This logic is correct (converts quote currency cost to account)
            commission_cost_acct_curr = (2.0 * Inp_StockCommissionCost) * g_conversion_rate;
        }
            
        risk_per_lot_acct_curr += commission_cost_acct_curr;
    }
    
    if(risk_per_lot_acct_curr <= 0) 
    {
        Print("CalculateLotSize: Total risk per lot is zero or negative for ", _Symbol);
        return 0.0;
    }
    
    double lot_size = risk_amount_acct_curr / risk_per_lot_acct_curr;
    
    double min_vol = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN);
    double max_vol = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MAX);
    double step_vol = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_STEP);
    
    lot_size = MathMax(lot_size, min_vol);
    lot_size = MathMin(lot_size, max_vol);
    lot_size = floor(lot_size / step_vol) * step_vol;
    
    return NormalizeDouble(lot_size, 2);
}

//+------------------------------------------------------------------+
//| Get Currency Conversion Rate (FIXED AND ROBUST)                  |
//+------------------------------------------------------------------+
double GetConversionRate(string from_currency, string to_currency)
{
    if(from_currency == to_currency) return 1.0;

    // Loop through all symbols in Market Watch to find the pair
    for(int i = 0; i < SymbolsTotal(false); i++)
    {
        string symbol = SymbolName(i, false);
        string base_curr, quote_curr;
        
        // Check if symbol info is available
        if(SymbolInfoString(symbol, SYMBOL_CURRENCY_BASE, base_curr) && SymbolInfoString(symbol, SYMBOL_CURRENCY_PROFIT, quote_curr))
        {
            // Case 1: Found direct pair (e.g., from_currency = USD, to_currency = AUD -> USDAUD)
            if(base_curr == from_currency && quote_curr == to_currency)
            {
                double bid = SymbolInfoDouble(symbol, SYMBOL_BID);
                if(bid > 0) return bid;
            }
            
            // Case 2: Found inverse pair (e.g., from_currency = USD, to_currency = AUD -> AUDUSD)
            if(base_curr == to_currency && quote_curr == from_currency)
            {
                double ask = SymbolInfoDouble(symbol, SYMBOL_ASK);
                // Must use 1.0 / ASK price for inverse rate
                if(ask > 0) return 1.0 / ask; 
            }
        }
    }

    // CRITICAL FIX: Return 0.0 on failure
    return 0.0;
}

double GetPipSize()
{
    if (_Point == 0) return 0.0;
    int digits = (int)SymbolInfoInteger(_Symbol, SYMBOL_DIGITS);
    int pip_multiplier = (digits % 2 == 1) ? 10 : 100;
    return _Point * pip_multiplier;
}
