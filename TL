//+------------------------------------------------------------------+
//| Expert initialization function (OnInit)                          |
//+------------------------------------------------------------------+
int OnInit()
{
    if(!TerminalInfoInteger(TERMINAL_CONNECTED))
    {
        Print("Client OnInit failed: No terminal connection.");
        return(INIT_FAILED);
    }

    double total_tp_volume = TP1_Volume + TP2_Volume + TP3_Volume + TP4_Volume + TP5_Volume + TP6_Volume + TP7_Volume;
    if(MathAbs(total_tp_volume - 100.0) > 0.01)
    {
        PrintFormat("CRITICAL ERROR: TP volumes sum to %.2f%%. They must sum to 100.0%%.", total_tp_volume);
        return(INIT_FAILED);
    }

    // GV Key Setup: ALIGNED WITH CCM's KEY GENERATION LOGIC
    string norm_symbol = GetNormalizedSymbol();
    string tf_str = TimeframeToString(Inp_Timeframe);
    g_gv_prefix = "CCM_" + norm_symbol + "_" + tf_str + "_";
    g_gv_commit_key = g_gv_prefix + "COMMIT_ID";
    
    for (int i = 0; i < CANDLE_LOOKBACK; i++) {
        g_gv_time_keys[i] = g_gv_prefix + "TIME_" + IntegerToString(i);
        g_gv_high_keys[i] = g_gv_prefix + "HIGH_" + IntegerToString(i);
        g_gv_low_keys[i] = g_gv_prefix + "LOW_" + IntegerToString(i);
        g_gv_height_keys[i] = g_gv_prefix + "HEIGHT_" + IntegerToString(i);
    }

    // --- ROBUST CONVERSION RATE INIT (from TradeLogic 1.51) ---
    string quote_currency = SymbolInfoString(_Symbol, SYMBOL_CURRENCY_MARGIN);
    string acct_currency = AccountInfoString(ACCOUNT_CURRENCY);
    
    const int max_init_attempts = 100;
    bool init_rate_success = false;
    
    for(int i = 1; i <= max_init_attempts; i++)
    {
        g_conversion_rate = GetConversionRate(quote_currency, acct_currency);
        if(g_conversion_rate > 0)
        {
            Print("Successfully obtained FX rate for use in calculating trade risk");
            init_rate_success = true;
            break; // Success, exit the loop
        }

        // Check if this is the final attempt
        if(i == max_init_attempts)
        {
            PrintFormat("Failed to get an FX conversion rate after %d attempts. Lot sizing will fail.", max_init_attempts);
            return(INIT_FAILED); // Final failure
        }

        // Log progress every 10 attempts (at 10, 20, ... 90)
        if(i % 10 == 0)
        {
            Print("Failed to get an FX conversion rate upon Initialisation. Will keep trying another 10 seconds");
        }
        
        Sleep(1000); // Wait 1 second before retrying
    }

    g_last_conversion_rate_time = TimeCurrent(); // Set the time for the OnTimer logic
    
    // We only reach this line if the loop succeeded
    PrintFormat("Initial conversion rate from %s to %s set: %.5f", quote_currency, acct_currency, g_conversion_rate);
    // --- END MODIFIED BLOCK ---

    g_next_magic_id = Inp_BaseMagicNumber;
    
    if(!Inp_ResetGlobalVars)
    {
        // Initialize last processed time from the correct GV
        if(GlobalVariableCheck(GVarLastCandleTimeName()))
            g_last_gv_processed_time = (datetime)GlobalVariableGet(GVarLastCandleTimeName());
        else if(GlobalVariableCheck(g_gv_commit_key)) // Fallback to live key
            g_last_gv_processed_time = (datetime)GlobalVariableGet(g_gv_commit_key);
        else
            g_last_gv_processed_time = 0;
    }
    else
    {
         g_last_gv_processed_time = 0;
         GlobalVariableDel(GVarLastCandleTimeName());
    }

    RebuildInternalState();

    EventSetTimer((int)Inp_TimerInterval);
    PrintFormat("TradeLogic Client Initialised. Polling Commit Key: '%s', Base Magic: %d", g_gv_commit_key, Inp_BaseMagicNumber);

    return(INIT_SUCCEEDED);
}

//+------------------------------------------------------------------+
//| Deinitialization Function                                        |
//+------------------------------------------------------------------+
void OnDeinit(const int reason)
{
    GlobalVariableSet(GVarLastCandleTimeName(), g_last_gv_processed_time);
    
    string saved_state_name = GVarSavedTradeStateName();
    string trade_state = SerializeOpenTrades();
    if (StringLen(trade_state) > 0) {
        SaveTradeStateToFile(saved_state_name, trade_state);
    }
    
    for(int i = 0; i < g_trade_groups.Total(); i++)
    {
        CTradeGroup *group = g_trade_groups.At(i);
        if(group != NULL) delete group;
    }
    g_trade_groups.Clear();
    
    // Clear verification queue
    for(int i = 0; i < g_verification_queue.Total(); i++)
    {
        S_OcoVerificationRequest *request = g_verification_queue.At(i);
        if(request != NULL) delete request;
    }
    g_verification_queue.Clear();
    
    EventKillTimer();
    Print("TradeLogic Client deinitialized. Reason: ", reason);
}


//+------------------------------------------------------------------+
//| OnTimer Function (CORRECTED)                                     |
//+------------------------------------------------------------------+
void OnTimer()
{
    datetime currentTime = TimeCurrent();

    // --- NEW: ROBUST PRE-SIGNAL CONVERSION RATE REFRESH ---
    // 1. Calculate the target signal close time based on inputs
    ENUM_TIMEFRAMES tf_period = GetNativeTimeframe(Inp_Timeframe);
    datetime day_start = currentTime - (currentTime % 86400);
    datetime target_signal_open_time = day_start + (Inp_CloseHour * 3600) + (Inp_CloseMinute * 60) - PeriodSeconds(tf_period);
    datetime target_signal_close_time = target_signal_open_time + PeriodSeconds(tf_period);

    // 2. Define the 5-second refresh window *before* the close
    datetime refresh_start_time = target_signal_close_time - 5;
    
    // 3. Check if we are inside the window AND haven't refreshed yet for this specific window
    if (currentTime >= refresh_start_time && currentTime < target_signal_close_time && g_last_conversion_rate_time < refresh_start_time)
    {
        string quote_currency = SymbolInfoString(_Symbol, SYMBOL_CURRENCY_MARGIN);
        string acct_currency = AccountInfoString(ACCOUNT_CURRENCY);
        double new_rate = 0.0;
        const int max_timer_attempts = 90;
        bool timer_rate_success = false;
        
        for(int i = 1; i <= max_timer_attempts; i++)
        {
            new_rate = GetConversionRate(quote_currency, acct_currency);
            if(new_rate > 0)
            {
                g_conversion_rate = new_rate; // Update the global with the fresh rate
                Print("Successfully obtained FRESH FX rate for use in calculating trade risk");
                timer_rate_success = true;
                break; // Success, exit retry loop
            }
            
            Sleep(100); // Wait 100ms before retrying
        }
        
        // After the loop, check if all attempts failed
        if(!timer_rate_success)
        {
            Print("Failed to get an FX conversion rate for the robot. X1 candle is aborted");
            // Set rate to 0.0 to force CalculateLotSize to return 0,
            // which skips the trade.
            g_conversion_rate = 0.0; 
        }

        g_last_conversion_rate_time = currentTime; // "Set the flag" to prevent re-refreshing in this window
    }
    // --- END PRE-SIGNAL REFRESH ---


    // --- STALENESS MONITOR ---
    string status_key = g_gv_prefix + "STATUS";
    if (GlobalVariableCheck(status_key))
    {
        datetime status_time = (datetime)GlobalVariableGet(status_key);
        if (status_time > 0)
        {
            long time_since_last_status = currentTime - status_time;
            long period_seconds = PeriodSeconds(GetNativeTimeframe(Inp_Timeframe));

            if (period_seconds > 0 && time_since_last_status > period_seconds * 3)
            {
                if (currentTime - g_last_staleness_log_time >= 600)
                {
                    PrintFormat("STALENESS WARNING: The CCM data feed for %s appears to be stalled. Last heartbeat was over %d minutes ago.",
                                _Symbol, (int)(time_since_last_status / 60));
                    g_last_staleness_log_time = currentTime;
                }
            }
        }
    }
    // --- END STALENESS MONITOR ---

    ProcessGVPolling();
    
    // --- THIS IS THE FIX ---
    // Process the OCO verification queue
    for(int i = g_verification_queue.Total() - 1; i >= 0; i--)
    {
        S_OcoVerificationRequest *request = (S_OcoVerificationRequest*)g_verification_queue.At(i);
        if(request != NULL && currentTime >= request.check_after_time)
        {
            // Check the return value. Only delete if true (cleanup is finished).
            if(VerifyAndCleanOcoImbalance(request.magic_number))
            {
                // Cleanup was successful or not needed. Job is "DONE".
                delete request;
                g_verification_queue.Delete(i);
            }
            else
            {
                // Cleanup failed (e.g., delete error).
                // Reschedule the check for 10 seconds from now.
                PrintFormat("Magic %d: OCO verification FAILED (e.g., delete failed). Retrying in 10s.", request.magic_number);
                request.check_after_time = currentTime + 10; 
            }
        }
    }
    // --- END FIX ---


    // Heartbeat for this EA
    static datetime lastHeartbeat = 0;
    if (currentTime - lastHeartbeat >= 300)
    {
        string heartbeatKey = StringFormat("TL_%d_Heartbeat", Inp_BaseMagicNumber);
        double heartbeatValue = (double)currentTime;
        GlobalVariableSet(heartbeatKey, heartbeatValue);
        lastHeartbeat = currentTime;
    }
}

//+------------------------------------------------------------------+
//| Expert tick function (OnTick)                                    |
//+------------------------------------------------------------------+
void OnTick()
{
    if (Inp_EndDay == ED_Yes)
    {
        datetime currentTime = TimeCurrent();
        datetime day_start = currentTime - (currentTime % 86400);
        datetime eod_time = day_start + (Inp_EndHour * 3600) + (Inp_EndMinute * 60);
        
        // Check EOD cleanup only 1 minute before end time
        if (currentTime >= eod_time - 60 && currentTime < eod_time)
        {
            if(TimeCurrent() - g_last_eod_check > 60) // Prevent multiple runs in the same minute
            {
                 MqlDateTime structTime;
                 TimeToStruct(day_start, structTime);
                 if (structTime.day_of_week != 0 && structTime.day_of_week != 6) // Exclude Sat/Sun
                 {
                     PerformEODCleanup();
                     g_last_eod_check = TimeCurrent();
                 }
            }
        }
    }
}

//+------------------------------------------------------------------+
//| Trade Transaction Handler for OCO Logic                          |
//+------------------------------------------------------------------+
void OnTradeTransaction(const MqlTradeTransaction& trans,
                        const MqlTradeRequest& request,
                        const MqlTradeResult& result)
{
    if(trans.type == TRADE_TRANSACTION_DEAL_ADD)
    {
        if(HistoryDealSelect(trans.deal) && HistoryDealGetInteger(trans.deal, DEAL_ENTRY) == DEAL_ENTRY_IN)
        {
            long magic = HistoryDealGetInteger(trans.deal, DEAL_MAGIC);
            CTradeGroup *group = GetTradeGroup(magic);
            if(group != NULL && !group.oco_complete)
            {
                HandleOCO(magic);
            }
        }
    }
}


//+------------------------------------------------------------------+
//| CORE: GV Polling and Signal Processing (Handshake Version)       |
//+------------------------------------------------------------------+
void ProcessGVPolling()
{
    // --- NEW HANDSHAKE POLLING LOGIC ---

    // 1. Check for the commit key and get its value (the timestamp of the last committed candle).
    if (!GlobalVariableCheck(g_gv_commit_key)) return; // If commit key doesn't exist, CCM is not ready.

    datetime commit_time = (datetime)GlobalVariableGet(g_gv_commit_key);
    
    // 2. CRITICAL CHECK: Only proceed if this commit timestamp is NEWER than the last one we processed.
    if (commit_time <= g_last_gv_processed_time) return;

    // --- Signal Confirmed: Now it's safe to read the full data package ---

    // 3. Optional but good practice: Validate that the core GVs still exist.
    if (!ValidateGV())
    {
        Print("COMMIT_ID found, but core GVs are missing. Waiting for CCM to sync.");
        return; // A safety check
    }

    S_CCM_CANDLE latest_candle;
    int latest_candle_index = CANDLE_LOOKBACK - 1; // Index 2

    // 4. Read the full data package with confidence.
    latest_candle.Time   = (datetime)GlobalVariableGet(g_gv_time_keys[latest_candle_index]);
    latest_candle.High   = (double)GlobalVariableGet(g_gv_high_keys[latest_candle_index]);
    latest_candle.Low    = (double)GlobalVariableGet(g_gv_low_keys[latest_candle_index]);
    latest_candle.Height = (double)GlobalVariableGet(g_gv_height_keys[latest_candle_index]);
    
    // Sanity check: Ensure the time from the buffer matches the commit time.
    if(latest_candle.Time != commit_time)
    {
        PrintFormat("GV Mismatch Warning: COMMIT_ID time (%s) does not match TIME_%d time (%s). Data may be inconsistent.",
                    TimeToString(commit_time), latest_candle_index, TimeToString(latest_candle.Time));
        // We still update the processed time to avoid a loop, but we don't trade.
        g_last_gv_processed_time = commit_time;
        return;
    }

    // --- SIGNAL LOGIC (Targeting CloseHour/Minute) ---
    ENUM_TIMEFRAMES tf_period = GetNativeTimeframe(Inp_Timeframe);
    datetime day_start = TimeCurrent() - (TimeCurrent() % 86400);
    datetime target_timestamp = day_start + (Inp_CloseHour * 3600) + (Inp_CloseMinute * 60) - PeriodSeconds(tf_period);
    datetime target_start_time = target_timestamp;
    datetime target_end_time   = target_start_time + PeriodSeconds(tf_period);
    
    // Check if the NEW GV signal's open time falls WITHIN the target window
    if (latest_candle.Time >= target_start_time && latest_candle.Time < target_end_time)
    {
        // 1. MinX1Height filter remains here
        if(latest_candle.Height < MinX1Height)
        {
            PrintFormat("SIGNAL SKIPPED: MinX1Height (%d) filter failed. Height: %.2f",
                        MinX1Height, latest_candle.Height);
            g_last_gv_processed_time = commit_time; // IMPORTANT: Update with commit_time
            return;
        }

        // 2. Check for existing trades
        bool trade_group_exists = false;
        for(int i = 0; i < g_trade_groups.Total(); i++)
        {
            CTradeGroup *group = g_trade_groups.At(i);
            if(group != NULL && !group.oco_complete &&
               (group.buy_stop_tickets.Total() > 0 || group.sell_stop_tickets.Total() > 0 || group.open_position_tickets.Total() > 0))
            {
                PrintFormat("SIGNAL MATCH FOUND, BUT SKIPPING: Uncompleted trade group (Magic %d) exists. Will try next cycle.", group.magic_number);
                trade_group_exists = true;
                break;
            }
        }

        // 3. Place orders
        if (!trade_group_exists)
        {
            datetime close_time = latest_candle.Time + PeriodSeconds(tf_period);
            PrintFormat("GV SIGNAL MATCH: Target close time %s found! High=%.5f, Low=%.5f, Height=%.2f.",
                        TimeToString(close_time, TIME_DATE|TIME_MINUTES), latest_candle.High, latest_candle.Low, latest_candle.Height);
            if (Inp_AutoTrading == On)
            {
                PlaceOcoOrders(latest_candle.High, latest_candle.Low, close_time);
            }
        }
    }
    else if (latest_candle.Time > target_timestamp)
    {
         PrintFormat("INFO: New signal found at %s. Target time %s was missed.",
               TimeToString(latest_candle.Time), TimeToString(target_timestamp));
    }

    // IMPORTANT: Update the last processed time to prevent reprocessing this signal
    g_last_gv_processed_time = commit_time;
    GlobalVariableSet(GVarLastCandleTimeName(), g_last_gv_processed_time); // Also save to GV
}

//+------------------------------------------------------------------+
//| CORE FUNCTION: Places OCO bracket orders                         |
//+------------------------------------------------------------------+
void PlaceOcoOrders(double signal_high, double signal_low, datetime signal_close_time)
{
    // 1. Calculate Risk
    double risk_amount_acct_curr = (RPTFixedAmount > 0) ?
                                   RPTFixedAmount : account.Balance() * (RPTPercent / 100.0);
    if(risk_amount_acct_curr <= 0)
    {
        Print("PlaceOcoOrders: Calculated total risk amount is zero or negative. Aborting.");
        return;
    }
    
    // --- CONVERSION RATE CHECK ---
    // The g_conversion_rate is now set by OnInit and refreshed by OnTimer.
    // We just check if it's valid.
    if(g_conversion_rate <= 0.0)
    {
        Print("PlaceOcoOrders: g_conversion_rate is zero. Aborting. Check OnInit logic.");
        return;
    }
    // --- END CHECK ---

    // 2. Generate Magic Number and Group
    long magic_number = g_next_magic_id++;
    CTradeGroup *group = GetTradeGroup(magic_number, true);
    trade.SetExpertMagicNumber(magic_number);

    // 3. Place Buy Side
    double entry_buffer_buy = (signal_high - signal_low) * (Inp_TriggerPercent_Half / 100.0);
    double entry_price_buy = NormalizePrice(signal_high + entry_buffer_buy);
    if (!CheckLeapfrog(entry_price_buy, ORDER_TYPE_BUY_STOP, TimeCurrent()))
    {
       PlaceOrdersForSide(magic_number, ORDER_TYPE_BUY_STOP, signal_high, signal_low, risk_amount_acct_curr);
    }

    // 4. Place Sell Side
    double entry_buffer_sell = (signal_high - signal_low) * (Inp_TriggerPercent_Half / 100.0);
    double entry_price_sell = NormalizePrice(signal_low - entry_buffer_sell);
    if (!CheckLeapfrog(entry_price_sell, ORDER_TYPE_SELL_STOP, TimeCurrent()))
    {
       PlaceOrdersForSide(magic_number, ORDER_TYPE_SELL_STOP, signal_high, signal_low, risk_amount_acct_curr);
    }
    
    // 5. Schedule Verification (NEW LOGIC, CORRECT PLACEMENT)
    S_OcoVerificationRequest *request = new S_OcoVerificationRequest();
    if(request != NULL) // Always check if new succeeded
    {
        request.magic_number = magic_number;
        // NEW: Schedule the check 30 seconds AFTER the signal candle's close time
        request.check_after_time = signal_close_time + 30;
        g_verification_queue.Add(request);
        PrintFormat("Magic %d: OCO verification scheduled for %s (30s after signal close)", magic_number, TimeToString(request.check_after_time, TIME_SECONDS));
    }
}

//+------------------------------------------------------------------+
//| // CORE FUNCTION: Places orders for one side (buy or sell) of OCO   |
//+------------------------------------------------------------------+
void PlaceOrdersForSide(long magic_number, ENUM_ORDER_TYPE orderType, double signal_high, double signal_low, double risk_amount_acct_curr)
{
    const int total_orders = TOTAL_TPS;
    double candle_height = signal_high - signal_low;
    
    if(MathAbs(candle_height) < _Point) return;

    double entry_pct_input = (orderType == ORDER_TYPE_BUY_STOP) ? Inp_TriggerPercent_Half : Inp_TriggerPercent_Half;
    double sl_pct_input = Inp_StopLossPercent_Half;
    
    double entry_buffer = candle_height * (entry_pct_input / 100.0);
    double sl_buffer = candle_height * (sl_pct_input / 100.0);
    double entry_price = (orderType == ORDER_TYPE_BUY_STOP) ? NormalizePrice(signal_high + entry_buffer) : NormalizePrice(signal_low - entry_buffer);
    double sl_price = (orderType == ORDER_TYPE_BUY_STOP) ? NormalizePrice(signal_low - sl_buffer) : NormalizePrice(signal_high + sl_buffer);

    double current_bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
    double current_ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
    if(orderType == ORDER_TYPE_BUY_STOP && entry_price <= current_ask)
    {
        PrintFormat("Invalid BUY STOP entry price %.5f (below or equal to ask %.5f). Skipping.", entry_price, current_ask);
        return;
    }
    if(orderType == ORDER_TYPE_SELL_STOP && entry_price >= current_bid)
    {
        PrintFormat("Invalid SELL STOP entry price %.5f (above or equal to bid %.5f). Skipping.", entry_price, current_bid);
        return;
    }
    
    double tp_distances[] = {TP1_Distance, TP2_Distance, TP3_Distance, TP4_Distance, TP5_Distance, TP6_Distance, TP7_Distance};
    double tp_volumes[] = {TP1_Volume/100.0, TP2_Volume/100.0, TP3_Volume/100.0, TP4_Volume/100.0, TP5_Volume/100.0, TP6_Volume/100.0, TP7_Volume/100.0};
    
    CTradeGroup *group = GetTradeGroup(magic_number);
    if(group == NULL) return;
    CArrayLong *tickets_array = (orderType == ORDER_TYPE_BUY_STOP) ? &group.buy_stop_tickets : &group.sell_stop_tickets;
    
    for(int i = 0; i < total_orders; i++)
    {
        if(tp_volumes[i] <= 0) continue;
        double riskForThisOrder = risk_amount_acct_curr * tp_volumes[i];
        double lot_size = CalculateLotSize(riskForThisOrder, sl_price, entry_price, sl_buffer);
        
        if(lot_size < SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN))
        {
            PrintFormat("LOT SIZE WARNING (%s TP%d, Magic %d): Calculated lot (%.2f) too small. Skipped.", (orderType == ORDER_TYPE_BUY_STOP ? "BUY" : "SELL"), i+1, magic_number, lot_size);
            continue;
        }

        double tp_distance_price = candle_height * (tp_distances[i] / 100.0);
        double tp_price = (orderType == ORDER_TYPE_BUY_STOP) ? NormalizePrice(signal_high + tp_distance_price) : NormalizePrice(signal_low - tp_distance_price);
        
        MqlTradeRequest request; ZeroMemory(request);
        MqlTradeResult result; ZeroMemory(result);
        request.action = TRADE_ACTION_PENDING;
        request.magic = magic_number;
        request.symbol = _Symbol;
        request.volume = lot_size;
        request.price = entry_price;
        request.sl = sl_price;
        request.tp = tp_price;
        request.type = orderType;
        request.type_filling = (ENUM_ORDER_TYPE_FILLING)SymbolInfoInteger(_Symbol, SYMBOL_FILLING_MODE);
        request.type_time = ORDER_TIME_GTC;
        request.comment = StringFormat("TP%d_%.0f_%llu", i+1, tp_distances[i], magic_number);
        
        if(trade.OrderSend(request, result))
        {
            tickets_array.Add((long)result.order);
        }
        else
        {
            // --- ENHANCED LOGGING FOR FAILED OrderSend ---
            uint retcode = trade.ResultRetcode();
            string reason = "";

            // Use a switch to identify the precise reason
            switch(retcode)
            {
                // --- User's specific requests ---
                case TRADE_RETCODE_CONNECTION:
                    reason = "REASON: No connection to the trade server.";
                    break;
                case TRADE_RETCODE_INVALID_STOPS:
                    // This one case (10016) covers all invalid SL or TP issues.
                    reason = "REASON: Invalid Stop Loss or Take Profit levels (too close, wrong values).";
                    break;
                case TRADE_RETCODE_TRADE_DISABLED:
                    reason = "REASON: Trading is disabled (for this account, symbol, or by the EA).";
                    break;
                    
                // --- Other common critical errors ---
                case TRADE_RETCODE_INVALID_PRICE:
                    reason = "REASON: Invalid entry price (e.g., stop order is on the wrong side of the market).";
                    break;
                case TRADE_RETCODE_INVALID_VOLUME:
                    reason = "REASON: Invalid volume (too small, too large, or wrong step). Check lot sizing.";
                    break;
                case TRADE_RETCODE_NO_MONEY:
                    reason = "REASON: Not enough money (insufficient margin for the trade).";
                    break;
                case TRADE_RETCODE_MARKET_CLOSED:
                    reason = "REASON: The market is currently closed.";
                    break;
                case TRADE_RETCODE_REQUOTE:
                    reason = "REASON: Requote. The price has changed, and the order was rejected.";
                    break;

                // --- Default catch-all ---
                default:
                    // Fall back to the broker's comment if the code isn't handled above
                    reason = StringFormat("REASON: Unhandled error. Broker Comment: %s", trade.ResultComment());
                    break;
            }
            PrintFormat("OrderSend FAILED (Magic %d, TP%d, %s): Error Code %d. %s",
                        magic_number,
                        i+1,
                        (orderType == ORDER_TYPE_BUY_STOP ? "BUY_STOP" : "SELL_STOP"),
                        retcode,
                        reason);
       }
   }
}

