bool CheckLeapfrog(double entry_price, ENUM_ORDER_TYPE orderType, datetime signal_time)
{
    if (Inp_LeapfrogProtection == LFP_OFF) return false;
    double current_price = (orderType == ORDER_TYPE_BUY_STOP) ? SymbolInfoDouble(_Symbol, SYMBOL_ASK) : SymbolInfoDouble(_Symbol, SYMBOL_BID);
    if (orderType == ORDER_TYPE_BUY_STOP && current_price >= entry_price)
    {
        Print("Leapfrog detected for BUY STOP: Current ask >= entry. Skipping.");
        return true;
    }
    if (orderType == ORDER_TYPE_SELL_STOP && current_price <= entry_price)
    {
        Print("Leapfrog detected for SELL STOP: Current bid <= entry. Skipping.");
        return true;
    }
    return false;
}

//+------------------------------------------------------------------+
//| UTILITY: Delete All Tickets (CORRECTED: Cures "Amnesia Flaw")    |
//| RETURNS: true if all tickets were successfully deleted, false otherwise |
//+------------------------------------------------------------------+
bool DeleteAllTickets(CArrayLong& tickets_array, string side, long magic_number)
{
    int total_to_delete = tickets_array.Total();
    int success_count = 0;
    
    // Set the magic number for the CTrade object
    trade.SetExpertMagicNumber(magic_number);

    for (int i = total_to_delete - 1; i >= 0; i--)
    {
        ulong ticket = tickets_array.At(i);
        if (ticket > 0)
        {
            if(TryOrderDelete(ticket))
            {
                // Deletion was successful, remove it from our list
                tickets_array.Delete(i);
                success_count++;
            }
            else
            {
                // Deletion FAILED.
                // We *do not* remove it from the list.
                // The EA will try again on the next tick/check.
                PrintFormat("Magic %d: Failed to delete %s ticket %llu. Will retry.", magic_number, side, ticket);
            }
        }
        else
        {
             tickets_array.Delete(i); // Clean up an invalid 0 ticket
        }
    }

    // --- THIS IS THE FIX ---
    // Only return 'true' if the list is now empty.
    // If deletions failed, the list will still have tickets, and this will return 'false'.
    return(tickets_array.Total() == 0);
}

//+------------------------------------------------------------------+
//| TryOrderDelete (Corrected to handle "Ghost" tickets)             |
//+------------------------------------------------------------------+
bool TryOrderDelete(ulong ticket)
{
    // CTrade object's magic number is now set by the *calling function*
    if(trade.OrderDelete(ticket)) 
    {
        return true; // Standard success
    }
    
    // --- THIS IS THE FIX ---
    uint error = trade.ResultRetcode();
    
    // Check for "ghost" ticket errors
    if(error == TRADE_RETCODE_INVALID) // 10013 ("invalid request" - order is gone)
    {
        PrintFormat("TryOrderDelete: Ticket %llu is already gone (Error 10013). Treating as SUCCESS.", ticket);
        return true; // SUCCESS: The order is gone, which was the goal.
    }
    
    // Handle temporary network/server errors
    if(error == TRADE_RETCODE_REQUOTE || 
       error == TRADE_RETCODE_PRICE_CHANGED || 
       error == TRADE_RETCODE_CONNECTION)
    {
        Sleep(500); // Wait and try one more time
        if(trade.OrderDelete(ticket)) 
        {
            return true;
        }
    }
    
    // Log any other, more serious failure
    Print("TryOrderDelete: Failed to delete order #", ticket, ". Error: ", trade.ResultRetcode());
    return false;
}

